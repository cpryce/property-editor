{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/property.json",
  "title": "Property",
  "description": "A property record in the Property Editor application",
  "type": "object",
  "properties": {
    "id": {
      "description": "Auto-generated unique identifier (MongoDB ObjectId as string)",
      "type": "string",
      "pattern": "^[a-f0-9]{24}$"
    },
    "firstName": {
      "description": "First name of the person",
      "type": "string",
      "minLength": 1
    },
    "lastName": {
      "description": "Last name of the person",
      "type": "string",
      "minLength": 1
    },
    "gender": {
      "description": "Gender of the person",
      "type": "string",
      "enum": ["M", "F"]
    },
    "characterName": {
      "description": "Character name associated with the person",
      "type": "string",
      "minLength": 1
    },
    "createdAt": {
      "description": "Timestamp when the record was created (ISO 8601)",
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "description": "Timestamp when the record was last updated (ISO 8601)",
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["firstName", "lastName", "gender", "characterName"],
  "additionalProperties": false
}
