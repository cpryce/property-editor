{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/property.json",
  "title": "User",
  "description": "A property record in the Property Editor application",
  "type": "object",
  "properties": {
    "id": {
      "description": "Auto-generated unique identifier (MongoDB ObjectId as string)",
      "type": "string",
      "pattern": "^[a-f0-9]{24}$"
    },
    "firstName": {
      "type": "object",
      "title": "First Name",
      "properties": {
        "title": { "type": "string", "const": "First Name" },
        "value": { "type": "string", "minLength": 1 }
      },
      "required": ["title", "value"],
      "additionalProperties": false
    },
    "lastName": {
      "type": "object",
      "title": "Last Name",
      "properties": {
        "title": { "type": "string", "const": "Last Name" },
        "value": { "type": "string", "minLength": 1 }
      },
      "required": ["title", "value"],
      "additionalProperties": false
    },
    "gender": {
      "type": "object",
      "title": "Gender",
      "properties": {
        "title": { "type": "string", "const": "Gender" },
        "value": { "type": "string", "enum": ["M", "F"] }
      },
      "required": ["title", "value"],
      "additionalProperties": false
    },
    "characterName": {
      "type": "object",
      "title": "Character Name",
      "properties": {
        "title": { "type": "string", "const": "Character Name" },
        "value": { "type": "string", "minLength": 1 }
      },
      "required": ["title", "value"],
      "additionalProperties": false
    },
    "createdAt": {
      "description": "Timestamp when the record was created (ISO 8601)",
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "description": "Timestamp when the record was last updated (ISO 8601)",
      "type": "string",
      "format": "date-time"
    },
    "addresses": {
      "title": "Addresses",
      "description": "Zero or more addresses associated with this property record",
      "type": "array",
      "items": { "$ref": "https://example.com/schemas/address.json" }
    },
    "creditCards": {
      "title": "Credit Cards",
      "description": "Zero or more credit cards associated with this property record",
      "type": "array",
      "items": { "$ref": "https://example.com/schemas/creditCard.json" }
    }
  },
  "required": ["firstName", "lastName", "gender"],
  "allOf": [
    {
      "if": {
        "properties": { "addresses": { "minItems": 1 } },
        "required": ["addresses"]
      },
      "then": {
        "properties": {
          "addresses": {
            "contains": {
              "properties": { "isDefault": { "const": true } },
              "required": ["isDefault"]
            },
            "minContains": 1,
            "maxContains": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": { "creditCards": { "minItems": 1 } },
        "required": ["creditCards"]
      },
      "then": {
        "properties": {
          "creditCards": {
            "contains": {
              "properties": { "isDefault": { "const": true } },
              "required": ["isDefault"]
            },
            "minContains": 1,
            "maxContains": 1
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
